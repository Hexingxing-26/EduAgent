# === EduAgent Configuration ===

# LLM Provider: OpenAI 兼容接口
# 支持: OpenCode / DeepSeek / OpenAI / 硅基流动 等所有 OpenAI 兼容 API
LLM_API_KEY="sk-your-api-key-here"
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4o"

# === 备选 LLM 配置（根据需要取消注释）===
# DeepSeek:
# LLM_API_KEY="sk-your-deepseek-key"
# LLM_BASE_URL="https://api.deepseek.com/v1"
# LLM_MODEL="deepseek-chat"

# OpenCode:
# LLM_API_KEY="sk-your-opencode-key"
# LLM_BASE_URL="https://opencode.ai/zen/v1"
# LLM_MODEL="opencode-go/deepseek-v4-flash"

# 硅基流动 SiliconFlow:
# LLM_API_KEY="sk-your-siliconflow-key"
# LLM_BASE_URL="https://api.siliconflow.cn/v1"
# LLM_MODEL="Qwen/Qwen2.5-7B-Instruct"

# Database
# 默认 SQLite（零配置）；生产环境可切换 MySQL
DATABASE_URL="sqlite:///./edu_agent.db"

# JWT Authentication
# ⚠️ 请修改为随机字符串（至少 32 字符），可以用 https://randomkeygen.com 生成
JWT_SECRET_KEY="change-this-to-a-random-secret-at-least-32-chars"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Server Ports
BACKEND_PORT=8000
FRONTEND_PORT=80
